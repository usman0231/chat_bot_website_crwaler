# ============================================
# site-bot environment configuration
# 100% FREE local setup — no paid API keys needed.
# Copy this file to `.env` and adjust if needed.
# ============================================

# ----- Local LLM via Ollama -----
# Make sure Ollama is running:  https://ollama.com/download
# Verify it's up:  ollama --version
#
# Pull the model that fits your machine, then put its name in LLM_MODEL below.
#
#   Laptop / dev (8 GB RAM, no usable GPU):
#       ollama pull llama3.2:3b      ← LLM_MODEL=llama3.2:3b
#       (small, runs on CPU, good enough for code testing)
#
#   PC / demo (RTX 4060 Ti 8GB + 64 GB RAM):
#       ollama pull qwen2.5:7b       ← LLM_MODEL=qwen2.5:7b
#       (fits entirely in 8 GB VRAM, ~40-60 tokens/sec — DEMO READY)
#
#   PC heavy (if you want even better quality, runs partly on CPU):
#       ollama pull qwen2.5:14b      ← LLM_MODEL=qwen2.5:14b
#
# Ollama exposes an OpenAI-compatible API at http://localhost:11434/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama         # any non-empty string; Ollama ignores it
LLM_MODEL=qwen2.5:7b       # change to match your `ollama pull` above

# ----- API auth (for your own /bot/* endpoints) -----
# Any long random string. This is what your demo/Postman/curl will send
# in the X-API-Key header.
DEMO_API_KEY=change-me-to-a-long-random-string

# ----- User session JWTs -----
# HS256 secret for the per-user tokens issued by /auth/signup and /auth/login.
# Generate one with:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-64-character-random-secret-in-real-deployment

# Where the SQLite user table lives. Auto-created.
AUTH_DB_PATH=./data/auth.db

# ----- Stripe -----
# Test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Forward webhooks to dev:  stripe listen --forward-to localhost:8000/stripe/webhook
# Paste the printed whsec_ here.
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
# Price IDs for the recurring products
STRIPE_PRICE_PRO=price_replace_me_pro
STRIPE_PRICE_ENTERPRISE=price_replace_me_enterprise

# Used to build absolute Checkout success/cancel URLs.
APP_BASE_URL=http://localhost:3000

# ----- Embedding model -----
# Local, free, no API key needed. Runs on CPU (~80 MB download first time).
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ----- Crawler limits -----
MAX_PAGES=30
CRAWL_CONCURRENCY=5
HTTP_TIMEOUT=10

# ----- RAG behaviour -----
TOP_K=4
# Chroma returns DISTANCE (lower = more similar) for cosine. Range 0..2.
# Lower = stricter = more "I don't know" replies.
MAX_DISTANCE=0.65

# ----- Storage -----
CHROMA_PATH=./data/chroma
BOTS_REGISTRY_PATH=./data/bots.json

# ----- Server -----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ----- Voice calling — ElevenLabs TTS -----
# Sign up at https://elevenlabs.io and grab a key from Profile → API Keys.
# Free tier is ~10k chars/month; entry paid tier is $5/mo for ~30k chars.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Default voice (Sarah — a *premade* voice that works on free/starter
# keys; Rachel and professional/cloned voices 402 on free plans). Per-bot
# overrides live in bots.json under each bot's voice_id field.
ELEVENLABS_DEFAULT_VOICE=EXAVITQu4vr4xnSDxMaL
# Model — multilingual_v2 supports Urdu but with English-leaning phonetics.
ELEVENLABS_MODEL=eleven_multilingual_v2
# Output format. mp3_22050_32 = 22kHz @ 32kbps — small + fast over WS.
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
