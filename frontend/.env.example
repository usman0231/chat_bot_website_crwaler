NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=replace-with-your-api-key
# Optional: bot_id of a public demo bot. Shown as "Try the live demo" on the
# empty dashboard. Leave unset to hide the link.
NEXT_PUBLIC_DEMO_BOT_ID=
# Stripe publishable key (pk_test_... / pk_live_...). Used by the embedded
# Stripe Elements payment form on /pricing. If unset, the frontend falls
# back to whatever the backend returns from /stripe/payment/create-intent.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
